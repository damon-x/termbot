# TermBotV2 Environment Variables
# Copy this file to .env and fill in your values

# ── LLM Configuration ──────────────────────────────────────────────────────
# Provider: openai (OpenAI-compatible API) or anthropic (Anthropic native API)
LLM_PROVIDER=openai

# API Key
LLM_API_KEY=sk-your-api-key-here

# Base URL
# OpenAI:      https://api.openai.com/v1
# DeepSeek:    https://api.deepseek.com/v1
# DashScope:   https://dashscope.aliyuncs.com/compatible-mode/v1
# Anthropic:   https://api.anthropic.com  (when LLM_PROVIDER=anthropic)
LLM_BASE_URL=https://api.openai.com/v1

# Model name
LLM_MODEL=gpt-4o

# ── Embedding & Rerank (optional, for semantic memory search) ───────────────
# Currently supports DashScope (qwen). Leave empty to use keyword-only search.
EMBEDDING_API_KEY=
RERANK_API_KEY=

# ── Web Server (optional) ───────────────────────────────────────────────────
TERMBOT_HOST=0.0.0.0
TERMBOT_PORT=5000
SECRET_KEY=
